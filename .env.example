# Local PostgreSQL
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/green_activity"

# API server
PORT=3000
SESSION_SECRET=change-this-to-a-random-secret
NODE_ENV=development

# OpenAI (required for EcoBot chat and activity image verification)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key-here

# Frontend dev server (optional — defaults to 5173)
# PORT=5173
# API_PORT=3000
